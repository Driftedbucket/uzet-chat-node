// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url = env("DATABASE_URL")
}

model User{
  id           Int      @id @default(autoincrement())
  uzetId       String   @unique   // UZT-XXXX --> public identity
  name         String
  email        String   @unique
  passwordHash String
  createdAt    DateTime @default(now())

  sentRequests FriendRequest[] @relation("sent")
  receiveRequests FriendRequest[] @relation("received")
  
  sentMessages Message[] @relation("msgSent")
  receivedMessages Message[] @relation("msgReceived")
}

model FriendRequest{
  id Int @id  @default(autoincrement())
  fromUser User @relation("sent", fields: [fromUserId], references: [id])
  fromUserId Int
  toUser User @relation("received", fields: [toUserId], references: [id])
  toUserId Int
  note String?
  status String @default("PENDING") //pednig|accepted|dclined
  createdAt  DateTime @default(now())

  @@unique([fromUserId, toUserId])
}

model Message{
  id         Int      @id @default(autoincrement())
  fromUser   User     @relation("msgSent", fields: [fromUserId], references: [id])
  fromUserId Int
  toUser User @relation("msgReceived", fields:[toUserId], references:[id])
  toUserId Int
  type String   @default("text")  //text|sticker|voice|video
  content String 
  createdAt  DateTime @default(now())

  @@index([fromUserId, toUserId, createdAt])
}
